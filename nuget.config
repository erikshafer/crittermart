<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin restore to nuget.org only, for reproducible restores on any machine
    and on CI.

    The Critter Stack 2026 line (Wolverine 6.1, Marten 9.2, JasperFx 2.2) is
    published on nuget.org, so the private jasperfx feed
    (https://packages.jasperfx.net) is not needed by this repo. That feed is
    also auth-gated and returns 401 on the public CI runner, so it must NOT be
    a restore source here.

    The <clear /> drops any machine- or user-level sources (e.g. a global
    jasperfx entry). That also resolves the local NU1507 that central package
    management raises when more than one unmapped source is present, so no
    packageSourceMapping is needed with a single source.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
