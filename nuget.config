<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet sources, source mapping, and audit scoping.

    Why this file exists:
    * Without an explicit packageSourceMapping, central package management
      (Directory.Packages.props) plus more than one feed triggers NU1507 on
      restore ("multiple package sources defined but no source mapping").
    * The jasperfx feed does not implement the vulnerability-audit resource,
      so the restore-time NuGetAudit (and `dotnet list package` vulnerability
      scans) hit it with a 403. Scoping auditSources to nuget.org avoids that.

    Source mapping intent: everything resolves from nuget.org; the Critter
    Stack families (Wolverine / Marten / JasperFx / Weasel / Lamar / Polecat /
    CritterWatch) may ALSO come from the jasperfx feed, which is where the
    2026 line is published. The patterns cover transitive Critter packages,
    not just the ones pinned explicitly in Directory.Packages.props.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="jasperfx" value="https://packages.jasperfx.net/nuget/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="jasperfx">
      <package pattern="WolverineFx*" />
      <package pattern="Marten*" />
      <package pattern="JasperFx*" />
      <package pattern="Weasel*" />
      <package pattern="Lamar*" />
      <package pattern="Polecat*" />
      <package pattern="CritterWatch*" />
    </packageSource>
  </packageSourceMapping>

  <!-- Scope the vulnerability audit to nuget.org; the jasperfx feed 403s on the audit resource. -->
  <auditSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </auditSources>
</configuration>
