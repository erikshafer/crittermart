# Normalize all text files to LF on checkout so the `dotnet format` gate — and
# every contributor — sees identical bytes on Windows and CI (Linux). The repo's
# stored blobs are already LF (core.autocrlf normalized them on commit); this
# rule fixes the *checkout* side so a Windows working tree (autocrlf=true → CRLF)
# stops tripping the gate's end-of-line check. The binary types below override it
# (no conversion); shell scripts keep their explicit LF rule.
* text=auto eol=lf

*.ico binary
*.gif binary
*.png binary
*.jpg binary
*.dll binary
*.exe binary
*.pdb binary

# Shell scripts must always use Unix (LF) line endings.
# Without this, git on Windows (core.autocrlf=true) converts LF→CRLF on checkout,
# making the shebang #!/bin/bash\r, which causes Docker to fail with
# "cannot execute: required file not found" when mounting the script into
# /docker-entrypoint-initdb.d/.
*.sh text eol=lf
